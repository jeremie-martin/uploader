[Unit]
Description=uploader tick (oneshot: pick one due bundle across backends, resolve metadata, upload)

[Service]
Type=oneshot
WorkingDirectory=%h/prog/uploader
# uv lives in ~/.local/bin; keep it on PATH so `uv run` resolves.
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=%h/.local/bin/uv run --project %h/prog/uploader uploader tick
TimeoutStartSec=45min
# Per-project cadence is enforced inside the tick; this unit just runs one tick.
